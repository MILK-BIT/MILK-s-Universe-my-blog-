---
import Layout from '../../layouts/Layout.astro';
import StarField from '../../components/StarField.astro';
import { getCollection } from 'astro:content';

const photos = await getCollection('photography');

// 按日期排序
const sortedPhotos = photos.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const clusterColor = '#4ecdc4';
---

<Layout title="摄影 - 星辰博客" description="我的摄影作品">
  <StarField />

  <div class="photography-page">
    <div class="container">
      <header class="page-header">
        <div class="header-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="3"/>
            <circle cx="12" cy="12" r="8" stroke-dasharray="4 4"/>
            <circle cx="12" cy="4" r="1.5" fill="currentColor"/>
            <circle cx="20" cy="12" r="1.5" fill="currentColor"/>
            <circle cx="12" cy="20" r="1.5" fill="currentColor"/>
            <circle cx="4" cy="12" r="1.5" fill="currentColor"/>
          </svg>
        </div>
        <h1>摄影</h1>
        <p class="page-description">用镜头捕捉世界的美好，光影之间皆是故事</p>
        <div class="header-line" style={`--cluster-color: ${clusterColor}`}></div>
      </header>

      <div class="photo-grid">
        {sortedPhotos.map((photo, index) => (
          <a href={`/photography/${photo.slug}`} class="photo-card" style={`animation-delay: ${index * 0.1}s`}>
            <div class="card-glow"></div>
            <div class="photo-image">
              <img src={photo.data.image} alt={photo.data.title} loading="lazy" />
            </div>
            <div class="photo-overlay">
              <h3>{photo.data.title}</h3>
              <p class="photo-location">{photo.data.location}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>

<style>
  .photography-page {
    padding: var(--spacing-2xl) 0;
    min-height: 60vh;
    position: relative;
    z-index: 1;
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--spacing-2xl);
  }

  .header-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto var(--spacing-md);
    color: var(--cluster-color);
  }

  .header-icon svg {
    width: 100%;
    height: 100%;
  }

  .page-header h1 {
    margin-bottom: var(--spacing-sm);
    color: var(--cluster-color);
    text-shadow: 0 0 30px color-mix(in srgb, var(--cluster-color) 50%, transparent);
  }

  .page-description {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .header-line {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--cluster-color), transparent);
    margin: var(--spacing-lg) auto 0;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-md);
  }

  .photo-card {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--radius-md);
    cursor: pointer;
    background: rgba(20, 20, 35, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.08);
    animation: fadeInUp 0.6s ease forwards;
    opacity: 0;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .card-glow {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-md);
    opacity: 0;
    transition: opacity var(--transition-normal);
    pointer-events: none;
    z-index: 2;
    box-shadow: inset 0 0 0 2px var(--cluster-color);
  }

  .photo-card:hover .card-glow {
    opacity: 1;
  }

  .photo-image {
    width: 100%;
    height: 100%;
  }

  .photo-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-normal);
  }

  .photo-card:hover .photo-image img {
    transform: scale(1.1);
  }

  .photo-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--spacing-md);
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
    color: white;
    transform: translateY(100%);
    transition: transform var(--transition-normal);
    z-index: 1;
  }

  .photo-card:hover .photo-overlay {
    transform: translateY(0);
  }

  .photo-overlay h3 {
    font-size: 1.125rem;
    margin-bottom: 0.25rem;
  }

  .photo-location {
    font-size: 0.875rem;
    opacity: 0.9;
    color: var(--cluster-color);
  }

  @media (max-width: 1024px) {
    .photo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .photo-grid {
      grid-template-columns: 1fr;
    }

    .photo-overlay {
      transform: translateY(0);
      background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
    }
  }
</style>
