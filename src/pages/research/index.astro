---
import Layout from '../../layouts/Layout.astro';
import StarField from '../../components/StarField.astro';
import { getCollection } from 'astro:content';

const researches = await getCollection('research');

// 按日期排序
const sortedResearch = researches.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const clusterColor = '#a78bfa';
---

<Layout title="科研 - 星辰博客" description="我的科研成果">
  <StarField />

  <div class="research-page">
    <div class="container">
      <header class="page-header">
        <div class="header-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="3"/>
            <circle cx="12" cy="12" r="8" stroke-dasharray="4 4"/>
            <circle cx="12" cy="4" r="1.5" fill="currentColor"/>
            <circle cx="20" cy="12" r="1.5" fill="currentColor"/>
            <circle cx="12" cy="20" r="1.5" fill="currentColor"/>
            <circle cx="4" cy="12" r="1.5" fill="currentColor"/>
          </svg>
        </div>
        <h1>科研</h1>
        <p class="page-description">探索未知领域，记录学术研究的进展与成果</p>
        <div class="header-line" style={`--cluster-color: ${clusterColor}`}></div>
      </header>

      <div class="research-list">
        {sortedResearch.map((item, index) => (
          <a href={`/research/${item.slug}`} class="research-card" style={`animation-delay: ${index * 0.1}s`}>
            <div class="card-glow"></div>
            <div class="research-meta">
              <time>{new Date(item.data.date).getFullYear()}</time>
              {item.data.venue && <span class="venue">{item.data.venue}</span>}
            </div>
            <h3 class="research-title">{item.data.title}</h3>
            {item.data.authors && item.data.authors.length > 0 && (
              <p class="research-authors">
                {item.data.authors.join(', ')}
              </p>
            )}
            <div class="research-links">
              {item.data.pdf && (
                <span class="link-badge">PDF</span>
              )}
              {item.data.code && (
                <span class="link-badge">Code</span>
              )}
            </div>
            {item.data.tags && item.data.tags.length > 0 && (
              <div class="research-tags">
                {item.data.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>

<style>
  .research-page {
    padding: var(--spacing-2xl) 0;
    min-height: 60vh;
    position: relative;
    z-index: 1;
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--spacing-2xl);
  }

  .header-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto var(--spacing-md);
    color: var(--cluster-color);
  }

  .header-icon svg {
    width: 100%;
    height: 100%;
  }

  .page-header h1 {
    margin-bottom: var(--spacing-sm);
    color: var(--cluster-color);
    text-shadow: 0 0 30px color-mix(in srgb, var(--cluster-color) 50%, transparent);
  }

  .page-description {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .header-line {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--cluster-color), transparent);
    margin: var(--spacing-lg) auto 0;
  }

  .research-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    max-width: 800px;
    margin: 0 auto;
  }

  .research-card {
    position: relative;
    display: block;
    background: rgba(20, 20, 35, 0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
    transition: all var(--transition-normal);
    overflow: hidden;
    animation: fadeInUp 0.6s ease forwards;
    opacity: 0;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .card-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--cluster-color), transparent);
    opacity: 0;
    transition: opacity var(--transition-normal);
  }

  .research-card:hover {
    border-color: var(--cluster-color);
    transform: translateX(8px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3), 0 0 30px color-mix(in srgb, var(--cluster-color) 15%, transparent);
  }

  .research-card:hover .card-glow {
    opacity: 1;
  }

  .research-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-xs);
  }

  .research-meta time {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  .venue {
    font-size: 0.875rem;
    color: var(--cluster-color);
    font-weight: 500;
  }

  .research-title {
    font-size: 1.25rem;
    margin-bottom: var(--spacing-xs);
    color: var(--color-text);
    transition: color var(--transition-fast);
  }

  .research-card:hover .research-title {
    color: var(--cluster-color);
  }

  .research-authors {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-sm);
  }

  .research-links {
    display: flex;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-sm);
  }

  .link-badge {
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    background: rgba(167, 139, 250, 0.15);
    border: 1px solid rgba(167, 139, 250, 0.3);
    border-radius: 4px;
    color: var(--cluster-color);
  }

  .research-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    background: rgba(167, 139, 250, 0.1);
    color: var(--cluster-color);
    border: 1px solid rgba(167, 139, 250, 0.2);
    border-radius: 4px;
    font-weight: 500;
  }
</style>
