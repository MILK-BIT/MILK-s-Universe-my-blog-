---
import Layout from '../../layouts/Layout.astro';
import StarField from '../../components/StarField.astro';
import { getCollection } from 'astro:content';

const notes = await getCollection('notes');

// 按日期排序
const sortedNotes = notes.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const clusterColor = '#ff6b9d';
---

<Layout title="文稿 - 星辰博客" description="我的文稿与笔记">
  <StarField />

  <div class="notes-page">
    <div class="container">
      <header class="page-header">
        <div class="header-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="3"/>
            <circle cx="12" cy="12" r="8" stroke-dasharray="4 4"/>
            <circle cx="12" cy="4" r="1.5" fill="currentColor"/>
            <circle cx="20" cy="12" r="1.5" fill="currentColor"/>
            <circle cx="12" cy="20" r="1.5" fill="currentColor"/>
            <circle cx="4" cy="12" r="1.5" fill="currentColor"/>
          </svg>
        </div>
        <h1>文稿</h1>
        <p class="page-description">记录所思所想，分享技术与生活</p>
        <div class="header-line" style={`--cluster-color: ${clusterColor}`}></div>
      </header>

      <div class="notes-grid">
        {sortedNotes.map((note, index) => (
          <a href={`/notes/${note.slug}`} class="note-card" style={`animation-delay: ${index * 0.1}s`}>
            <div class="card-glow"></div>
            <div class="note-meta">
              <time>{new Date(note.data.date).toLocaleDateString('zh-CN')}</time>
            </div>
            <h3 class="note-title">{note.data.title}</h3>
            {note.data.description && (
              <p class="note-excerpt">{note.data.description}</p>
            )}
            {note.data.tags && note.data.tags.length > 0 && (
              <div class="note-tags">
                {note.data.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>

<style>
  .notes-page {
    padding: var(--spacing-2xl) 0;
    min-height: 60vh;
    position: relative;
    z-index: 1;
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--spacing-2xl);
  }

  .header-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto var(--spacing-md);
    color: var(--cluster-color);
  }

  .header-icon svg {
    width: 100%;
    height: 100%;
  }

  .page-header h1 {
    margin-bottom: var(--spacing-sm);
    color: var(--cluster-color);
    text-shadow: 0 0 30px color-mix(in srgb, var(--cluster-color) 50%, transparent);
  }

  .page-description {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .header-line {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--cluster-color), transparent);
    margin: var(--spacing-lg) auto 0;
  }

  .notes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--spacing-lg);
  }

  .note-card {
    position: relative;
    display: block;
    background: rgba(20, 20, 35, 0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
    transition: all var(--transition-normal);
    overflow: hidden;
    animation: fadeInUp 0.6s ease forwards;
    opacity: 0;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .card-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--cluster-color), transparent);
    opacity: 0;
    transition: opacity var(--transition-normal);
  }

  .note-card:hover {
    border-color: var(--cluster-color);
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3), 0 0 30px color-mix(in srgb, var(--cluster-color) 15%, transparent);
  }

  .note-card:hover .card-glow {
    opacity: 1;
  }

  .note-meta {
    margin-bottom: var(--spacing-xs);
  }

  .note-meta time {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .note-title {
    margin-bottom: var(--spacing-xs);
    color: var(--color-text);
    font-size: 1.25rem;
  }

  .note-card:hover .note-title {
    color: var(--cluster-color);
  }

  .note-excerpt {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--spacing-sm);
  }

  .note-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    background: rgba(255, 107, 157, 0.1);
    color: var(--cluster-color);
    border: 1px solid rgba(255, 107, 157, 0.2);
    border-radius: 4px;
    font-weight: 500;
  }

  @media (max-width: 640px) {
    .notes-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
