---
import Layout from '../../layouts/Layout.astro';
import StarField from '../../components/StarField.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const others = await getCollection('others');
  return others.map(item => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content, headings } = await item.render();

// 过滤出h2和h3标题用于目录
const toc = headings.filter((h: { depth: number }) => h.depth >= 2 && h.depth <= 3);

const formattedDate = new Date(item.data.date).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const clusterColor = '#fbbf24';
---

<Layout title={`${item.data.title} - 其他`} description={item.data.title}>
  <StarField />

  <article class="other-post">
    <!-- 左侧目录 -->
    {toc.length > 0 && (
      <nav class="toc">
        <div class="toc-title">目录</div>
        <ul class="toc-list">
          {toc.map((heading: { depth: number; slug: string; text: string }) => (
            <li class={`toc-item toc-level-${heading.depth}`}>
              <a href={`#${heading.slug}`}>{heading.text}</a>
            </li>
          ))}
        </ul>
      </nav>
    )}

    <div class="container">
      <header class="post-header">
        <a href="/others" class="back-link">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          返回列表
        </a>
        <div class="post-meta">
          <time>{formattedDate}</time>
          {item.data.tags && item.data.tags.length > 0 && (
            <div class="post-tags">
              {item.data.tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
        <h1>{item.data.title}</h1>
        <div class="header-line" style={`--cluster-color: ${clusterColor}`}></div>
      </header>

      <div class="post-content">
        <Content />
      </div>

      <footer class="post-footer">
        <a href="/others" class="back-link">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          返回列表
        </a>
      </footer>
    </div>
  </article>
</Layout>

<style>
  .other-post {
    padding: var(--spacing-2xl) 0;
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    display: flex;
    gap: var(--spacing-xl);
  }

  /* 目录样式 */
  .toc {
    position: sticky;
    top: 100px;
    width: 200px;
    flex-shrink: 0;
    height: fit-content;
    display: none;
  }

  @media (min-width: 1200px) {
    .toc {
      display: block;
      margin-left: -240px;
    }
  }

  .toc-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--spacing-sm);
    padding-bottom: var(--spacing-xs);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-item {
    margin-bottom: 0.5rem;
  }

  .toc-item a {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    transition: color var(--transition-fast);
    display: block;
    padding: 0.25rem 0;
    border-left: 2px solid transparent;
    padding-left: 0.75rem;
    transition: all var(--transition-fast);
  }

  .toc-item a:hover {
    color: #6b8cff;
    border-left-color: #6b8cff;
  }

  .toc-level-3 {
    padding-left: 0.5rem;
  }

  .toc-level-3 a {
    font-size: 0.75rem;
    opacity: 0.8;
  }

  .container {
    flex: 1;
    min-width: 0;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
    color: var(--cluster-color);
    font-size: 0.9375rem;
    transition: all var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-text);
    transform: translateX(-4px);
  }

  .back-link svg {
    transition: transform var(--transition-fast);
  }

  .back-link:hover svg {
    transform: translateX(-4px);
  }

  .post-header {
    margin-bottom: var(--spacing-xl);
    background: rgba(20, 20, 35, 0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
  }

  .post-header .back-link {
    display: inline-flex;
    margin-bottom: var(--spacing-md);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-sm);
    flex-wrap: wrap;
  }

  .post-meta time {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    background: rgba(251, 191, 36, 0.1);
    color: var(--cluster-color);
    border: 1px solid rgba(251, 191, 36, 0.2);
    border-radius: 4px;
    font-weight: 500;
  }

  .post-header h1 {
    font-family: var(--font-serif);
    color: var(--cluster-color);
    text-shadow: 0 0 30px color-mix(in srgb, var(--cluster-color) 30%, transparent);
  }

  .header-line {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, var(--cluster-color), transparent);
    margin-top: var(--spacing-lg);
  }

  /* Markdown 内容样式 */
  :global(.post-content) {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--color-text);
    background: rgba(20, 20, 35, 0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
  }

  :global(.post-content h2) {
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-md);
    font-family: var(--font-serif);
    color: var(--cluster-color);
    scroll-margin-top: 100px;
  }

  :global(.post-content h3) {
    margin-top: var(--spacing-lg);
    margin-bottom: var(--spacing-sm);
    color: var(--color-text);
    scroll-margin-top: 100px;
  }

  :global(.post-content p) {
    margin-bottom: var(--spacing-md);
  }

  :global(.post-content ul),
  :global(.post-content ol) {
    margin-bottom: var(--spacing-md);
    padding-left: var(--spacing-lg);
  }

  :global(.post-content li) {
    margin-bottom: var(--spacing-xs);
  }

  :global(.post-content code) {
    font-family: 'Fira Code', 'Consolas', monospace;
    font-size: 0.9em;
    background: rgba(255, 255, 255, 0.05);
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  :global(.post-content pre) {
    background-color: #1a1a2e;
    color: #f8f8f2;
    padding: var(--spacing-md);
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin: var(--spacing-md) 0;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  :global(.post-content pre code) {
    background: none;
    padding: 0;
    color: inherit;
    border: none;
  }

  :global(.post-content blockquote) {
    margin: var(--spacing-md) 0;
    padding: var(--spacing-sm) var(--spacing-md);
    border-left: 4px solid var(--cluster-color);
    background: rgba(251, 191, 36, 0.05);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    font-style: italic;
    color: var(--color-text-secondary);
  }

  :global(.post-content a) {
    color: var(--cluster-color);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  :global(.post-content a:hover) {
    color: var(--color-text);
  }

  :global(.post-content table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--spacing-md) 0;
  }

  :global(.post-content th),
  :global(.post-content td) {
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: var(--spacing-xs) var(--spacing-sm);
    text-align: left;
  }

  :global(.post-content th) {
    background: rgba(255, 255, 255, 0.05);
    font-weight: 600;
  }

  :global(.post-content hr) {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin: var(--spacing-xl) 0;
  }

  :global(.post-content img) {
    max-width: 100%;
    border-radius: var(--radius-md);
    margin: var(--spacing-md) 0;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .post-footer {
    margin-top: var(--spacing-2xl);
    padding-top: var(--spacing-lg);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  @media (max-width: 768px) {
    .post-header, :global(.post-content) {
      padding: var(--spacing-lg);
    }
  }
</style>
