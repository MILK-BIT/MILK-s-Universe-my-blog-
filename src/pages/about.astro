---
import Layout from '../layouts/Layout.astro';
import StarField from '../components/StarField.astro';
---

<Layout title="关于 - 星辰博客" description="关于我">
  <StarField />

  <div class="about-page">
    <div class="container">
      <div class="about-content">
        <div class="about-image">
          <div class="avatar-placeholder">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="3"/>
              <circle cx="12" cy="12" r="8" stroke-dasharray="4 4"/>
              <circle cx="12" cy="4" r="1.5" fill="currentColor"/>
              <circle cx="20" cy="12" r="1.5" fill="currentColor"/>
              <circle cx="12" cy="20" r="1.5" fill="currentColor"/>
              <circle cx="4" cy="12" r="1.5" fill="currentColor"/>
            </svg>
          </div>
        </div>

        <div class="about-text">
          <h1>关于我</h1>

          <p class="intro">
            你好！欢迎来到MILK的星辰博客。MILK是一个爱吃饭睡觉摄影跳舞的小女孩~
          </p>

          <h2>我做什么</h2>
          <p>
            我是一名探索者，在代码、文字与光影之间寻找平衡。欢迎进入我的宇宙
          </p>

          <h2>这个博客</h2>
          <p>
            这个博客建于 2024 年，像一片星空，分为四个星座：
          </p>
          <ul>
            <li><span class="star pink"></span> 文稿 - 记录所思所想</li>
            <li><span class="star cyan"></span> 摄影 - 捕捉光影瞬间</li>
            <li><span class="star purple"></span> 科研 - 探索未知领域</li>
            <li><span class="star yellow"></span> 其他 - 生活杂谈随想</li>
          </ul>

          <h2>联系我</h2>
          <p>
            如果你想和我交流，欢迎通过以下方式联系我：
          </p>
          <div class="contact-links">
            <a href="mailto:mie15525063800@outlook.com" class="contact-link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="M22 6L12 13L2 6"/>
              </svg>
              your@email.com
            </a>
            <a href="https://github.com/MILK-BIT" target="_blank" rel="noopener" class="contact-link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
              </svg>
              GitHub
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .about-page {
    padding: var(--spacing-2xl) 0;
    min-height: 60vh;
    position: relative;
    z-index: 1;
  }

  .about-content {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--spacing-2xl);
    max-width: 900px;
    margin: 0 auto;
  }

  .about-image {
    position: sticky;
    top: 100px;
    align-self: start;
  }

  .avatar-placeholder {
    width: 200px;
    height: 200px;
    margin: 0 auto;
    background: rgba(20, 20, 35, 0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 40px rgba(107, 140, 255, 0.2);
  }

  .avatar-placeholder svg {
    width: 80px;
    height: 80px;
    color: var(--color-accent);
    animation: pulse 3s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.05); }
  }

  .about-text {
    background: rgba(20, 20, 35, 0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
  }

  .about-text h1 {
    margin-bottom: var(--spacing-lg);
    font-family: var(--font-serif);
    background: linear-gradient(135deg, #fff 0%, var(--color-accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .about-text h2 {
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-sm);
    font-size: 1.25rem;
    color: var(--color-accent);
  }

  .intro {
    font-size: 1.25rem;
    color: var(--color-text);
    line-height: 1.7;
  }

  .about-text p {
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  .about-text ul {
    list-style: none;
    margin: var(--spacing-sm) 0;
  }

  .about-text li {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-xs) 0;
    font-size: 1.0625rem;
    color: var(--color-text);
  }

  .star {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    box-shadow: 0 0 10px currentColor;
  }

  .star.pink {
    background: #ff6b9d;
    color: #ff6b9d;
  }

  .star.cyan {
    background: #4ecdc4;
    color: #4ecdc4;
  }

  .star.purple {
    background: #a78bfa;
    color: #a78bfa;
  }

  .star.yellow {
    background: #fbbf24;
    color: #fbbf24;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-sm);
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-md);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-sm);
    width: fit-content;
    color: var(--color-text-secondary);
    transition: all var(--transition-fast);
  }

  .contact-link:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
    box-shadow: 0 0 20px rgba(107, 140, 255, 0.4);
  }

  .contact-link svg {
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .about-content {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .about-image {
      position: static;
    }

    .avatar-placeholder {
      width: 150px;
      height: 150px;
    }

    .avatar-placeholder svg {
      width: 60px;
      height: 60px;
    }

    .about-text {
      padding: var(--spacing-lg);
    }

    .contact-links {
      align-items: center;
    }

    .about-text li {
      justify-content: center;
    }

    .intro {
      font-size: 1.125rem;
    }
  }
</style>
