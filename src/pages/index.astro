---
import Layout from '../layouts/Layout.astro';
import StarField from '../components/StarField.astro';
import { getCollection } from 'astro:content';

// 获取所有文章
const notes = await getCollection('notes');
const photos = await getCollection('photography');
const research = await getCollection('research');
const others = await getCollection('others');

// 构建星辰数据
const stars = [
  ...notes.map(note => ({
    id: note.id,
    title: note.data.title,
    href: `/notes/${note.slug}`,
    cluster: 'notes',
    color: '#ff6b9d'
  })),
  ...photos.map(photo => ({
    id: photo.id,
    title: photo.data.title,
    href: `/photography/${photo.slug}`,
    cluster: 'photography',
    color: '#4ecdc4'
  })),
  ...research.map(item => ({
    id: item.id,
    title: item.data.title,
    href: `/research/${item.slug}`,
    cluster: 'research',
    color: '#a78bfa'
  })),
  ...others.map(item => ({
    id: item.id,
    title: item.data.title,
    href: `/others/${item.slug}`,
    cluster: 'others',
    color: '#fbbf24'
  }))
];

// 四个模块配置
const modules = [
  {
    title: '文稿',
    subtitle: '思想 · 记录',
    description: '记录所思所想，分享技术与生活',
    color: '#ff6b9d',
    href: '/notes',
    count: notes.length
  },
  {
    title: '摄影',
    subtitle: '光影 · 瞬间',
    description: '用镜头捕捉世界的美好',
    color: '#4ecdc4',
    href: '/photography',
    count: photos.length
  },
  {
    title: '科研',
    subtitle: '探索 · 发现',
    description: '学术研究与论文笔记',
    color: '#a78bfa',
    href: '/research',
    count: research.length
  },
  {
    title: '其他',
    subtitle: '生活 · 杂谈',
    description: '书单、工具与随想',
    color: '#fbbf24',
    href: '/others',
    count: others.length
  }
];

// 社交链接
const socialLinks = [
  { name: 'GitHub', href: 'https://github.com/MILK-BIT', icon: 'github' },
  { name: 'Bilibili', href: 'https://space.bilibili.com/249449102?spm_id_from=333.1007.0.0', icon: 'bilibili' },
  { name: '邮箱', href: 'mailto:mie15525063800@outlook.com', icon: 'email' }
];
---

<Layout title="首页 - 星辰博客" fullScreen>
  <StarField stars={stars} showInteractive={true} />

  <!-- 第一页：星辰展示 -->
  <section class="page page-1">
    <div class="page-content">
      <div class="hero-text">
        <h1 class="hero-title">
          <span class="title-line">MILKの</span>
          <span class="title-line">universe</span>
        </h1>
        <p class="hero-subtitle">Reach for the stars and never settle for less.</p>
        <p class = "hero-subtitle-CN">追逐星星，永不满足于平凡。</p>
      </div>

      <div class="scroll-hint">
        <span>向下滚动探索更多</span>
        <div class="scroll-arrow">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 5v14M5 12l7 7 7-7"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- 第二页：个人介绍 -->
  <section class="page page-2">
    <div class="page-content">
      <div class="about-card glass">
        <div class="about-header">
          <div class="avatar">
            <img src="/pictures/20230309220806_71014.thumb.1000_0.jpg" alt="头像" />
          </div>
          <h2>关于我</h2>
        </div>

        <div class="about-text">
          <p class="intro">
            你好！欢迎来到MILK的星辰博客。<br>
            MILK是这个宇宙的主人，欢迎你来做客~
          </p>
          <p>
            我是一名探索者，在代码、文字与光影之间寻找平衡。<br>
            相信每个人都是宇宙中独特的星辰，通过分享与交流，我们可以互相照亮。
          </p>
        </div>

        <div class="social-links">
          {socialLinks.map(link => (
            <a href={link.href} class="social-link" target="_blank" rel="noopener noreferrer">
              {link.icon === 'github' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
                </svg>
              )}
              {link.icon === 'bilibili' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 0 1-.373-.906c0-.356.124-.658.373-.907l.027-.027c.267-.249.573-.373.92-.373.347 0 .653.124.92.373L9.653 4.44c.071.071.134.142.187.213h4.267a.836.836 0 0 1 .16-.213l2.853-2.747c.267-.249.573-.373.92-.373.347 0 .662.151.929.4.267.249.391.551.391.907 0 .355-.124.657-.373.906zM5.333 7.24c-.746.018-1.373.276-1.88.773-.506.498-.769 1.13-.786 1.894v7.52c.017.764.28 1.395.786 1.893.507.498 1.134.756 1.88.773h13.334c.746-.017 1.373-.275 1.88-.773.506-.498.769-1.129.786-1.893v-7.52c-.017-.765-.28-1.396-.786-1.894-.507-.497-1.134-.755-1.88-.773zM8 11.107c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c0-.373.129-.689.386-.947.258-.257.574-.386.947-.386zm8 0c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c.017-.391.15-.711.4-.96.249-.249.56-.373.933-.373z"/>
                </svg>
              )}
              {link.icon === 'email' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="2" y="4" width="20" height="16" rx="2"/>
                  <path d="M22 6l-10 7L2 6"/>
                </svg>
              )}
              <span>{link.name}</span>
            </a>
          ))}
        </div>

        <div class="stats">
          <div class="stat-item">
            <span class="stat-number">{notes.length + photos.length + research.length + others.length}</span>
            <span class="stat-label">篇文章</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">4</span>
            <span class="stat-label">个星座</span>
          </div>
        </div>
      </div>

      <div class="scroll-hint">
        <span>继续探索</span>
        <div class="scroll-arrow">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 5v14M5 12l7 7 7-7"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- 第三页：模块入口 -->
  <section class="page page-3">
    <div class="page-content">
      <h2 class="section-title">探索星座</h2>
      <p class="section-subtitle">选择一个星座，开始你的探索之旅</p>

      <div class="modules-grid">
        {modules.map((module, index) => (
          <a href={module.href} class="module-card glass" style={`--module-color: ${module.color}; animation-delay: ${index * 0.1}s`}>
            <div class="module-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="3"/>
                <circle cx="12" cy="12" r="8" stroke-dasharray="4 4"/>
                <circle cx="12" cy="4" r="1.5" fill="currentColor"/>
                <circle cx="20" cy="12" r="1.5" fill="currentColor"/>
                <circle cx="12" cy="20" r="1.5" fill="currentColor"/>
                <circle cx="4" cy="12" r="1.5" fill="currentColor"/>
              </svg>
            </div>
            <div class="module-info">
              <h3 class="module-title" style={`color: ${module.color}`}>{module.title}</h3>
              <span class="module-subtitle">{module.subtitle}</span>
              <p class="module-desc">{module.description}</p>
            </div>
            <div class="module-count">
              <span class="count-number" style={`color: ${module.color}`}>{module.count}</span>
              <span class="count-label">篇</span>
            </div>
            <div class="module-glow" style={`--module-color: ${module.color}`}></div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  /* 页面容器 */
  .page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
    scroll-snap-align: start;
    flex-shrink: 0;
  }


  .page-content {
    width: 100%;
    max-width: 1200px;
    padding: var(--spacing-xl) var(--spacing-md);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .page > * {
    pointer-events: auto;
  }

  :global(html) {
    scroll-snap-type: y mandatory;
    scroll-behavior: smooth;
  }

  .page-content {
    width: 100%;
    max-width: 1200px;
    padding: var(--spacing-xl) var(--spacing-md);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* 第一页 */
  .page-1 {
    pointer-events: none;
  }

  .page-1 .hero-text,
  .page-1 .scroll-hint {
    pointer-events: auto;
  }

  .page-1 .page-content {
    justify-content: center;
    min-height: 100vh;
    pointer-events: none;
  }

  .hero-text {
    text-align: center;
    margin-bottom: var(--spacing-2xl);
  }

  .hero-title {
    font-size: 4.5rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: var(--spacing-md);
    font-family: var(--font-serif);
  }

  .title-line {
    display: block;
    background: linear-gradient(135deg, #fff 0%, var(--color-accent) 50%, #a78bfa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: fadeInUp 1s ease forwards;
    opacity: 0;
  }

  .title-line:nth-child(1) { animation-delay: 0.2s; }
  .title-line:nth-child(2) { animation-delay: 0.4s; }

  .hero-subtitle {
    font-size: 2rem;
    font-family: "Edwardian Script ITC", "Brush Script MT", cursive;
    color: var(--color-text-secondary);
    animation: fadeInUp 1s ease 0.6s forwards;
    opacity: 0;
    letter-spacing: 0.05em;
  }
  .hero-subtitle-CN {
    font-size: 1rem;
    font-family: "Edwardian Script ITC", "Brush Script MT", cursive;
    color: var(--color-text-secondary);
    animation: fadeInUp 1s ease 0.6s forwards;
    opacity: 0;
    letter-spacing: 0.05em;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .scroll-hint {
    position: absolute;
    bottom: var(--spacing-2xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-sm);
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    animation: bounce 2s infinite;
  }

  .scroll-arrow {
    animation: arrowBounce 2s infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  @keyframes arrowBounce {
    0%, 100% { transform: translateY(0); opacity: 0.5; }
    50% { transform: translateY(5px); opacity: 1; }
  }

  /* 第二页：个人介绍 */
  .page-2 {
    z-index: 10;
    background: rgba(10, 10, 15, 0.95);
    padding-top: 100px;
  }
  .page-2 .page-content {
    justify-content: center;
    gap: var(--spacing-2xl);
  }

  .about-card {
    max-width: 600px;
    padding: var(--spacing-2xl);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .about-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
  }

  .avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--color-accent);
    box-shadow: 0 0 30px rgba(107, 140, 255, 0.4);
    animation: pulse 3s ease-in-out infinite;
  }

  .avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.05); }
  }

  .about-header h2 {
    font-size: 2rem;
    background: linear-gradient(135deg, #fff 0%, var(--color-accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .about-text {
    margin-bottom: var(--spacing-xl);
  }

  .about-text .intro {
    font-size: 1.125rem;
    color: var(--color-text);
    margin-bottom: var(--spacing-md);
    line-height: 1.8;
  }

  .about-text p {
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .social-links {
    display: flex;
    justify-content: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    padding: var(--spacing-sm) var(--spacing-md);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-sm);
    color: var(--color-text-secondary);
    transition: all var(--transition-fast);
  }

  .social-link:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
    box-shadow: 0 0 20px rgba(107, 140, 255, 0.4);
  }

  .stats {
    display: flex;
    justify-content: center;
    gap: var(--spacing-2xl);
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin-top: 0.25rem;
  }

  /* 第三页：模块入口 */
  .page-3 {
    z-index: 10;
    background: rgba(10, 10, 15, 0.95);
    padding-top: 100px;
  }
  .page-3 .page-content {
    justify-content: center;
    gap: var(--spacing-xl);
  }

  .section-title {
    font-size: 2.5rem;
    text-align: center;
    background: linear-gradient(135deg, #fff 0%, var(--color-accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 1.125rem;
  }

  .modules-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-lg);
    width: 100%;
    max-width: 900px;
    margin-top: var(--spacing-xl);
  }

  .module-card {
    position: relative;
    padding: var(--spacing-xl);
    border-radius: var(--radius-lg);
    transition: all var(--transition-normal);
    overflow: hidden;
    animation: fadeInUp 0.6s ease forwards;
    opacity: 0;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .module-card:hover {
    transform: translateY(-8px);
    border-color: var(--module-color);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3), 0 0 40px color-mix(in srgb, var(--module-color) 20%, transparent);
  }

  .module-icon {
    width: 48px;
    height: 48px;
    color: var(--module-color);
    margin-bottom: var(--spacing-sm);
  }

  .module-icon svg {
    width: 100%;
    height: 100%;
  }

  .module-title {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
    text-shadow: 0 0 20px color-mix(in srgb, var(--module-color) 50%, transparent);
  }

  .module-subtitle {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    display: block;
    margin-bottom: var(--spacing-sm);
  }

  .module-desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .module-count {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    margin-top: var(--spacing-md);
    padding-top: var(--spacing-sm);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .count-number {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
  }

  .count-label {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .module-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--module-color), transparent);
    opacity: 0.5;
    transition: opacity var(--transition-normal);
  }

  .module-card:hover .module-glow {
    opacity: 1;
  }

  /* 响应式 */
  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.5rem;
    }

    .hero-subtitle {
      font-size: 1rem;
    }

    .about-card {
      padding: var(--spacing-lg);
    }

    .avatar {
      width: 80px;
      height: 80px;
    }

    .about-header h2 {
      font-size: 1.5rem;
    }

    .social-links {
      flex-wrap: wrap;
    }

    .social-link {
      padding: var(--spacing-xs) var(--spacing-sm);
      font-size: 0.875rem;
    }

    .modules-grid {
      grid-template-columns: 1fr;
    }

    .section-title {
      font-size: 1.75rem;
    }

    .module-card {
      padding: var(--spacing-lg);
    }
  }
</style>
