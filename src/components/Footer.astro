---
const socialLinks = [
  { name: 'GitHub', href: 'https://github.com/MILK-BIT', icon: 'github' },
  { name: 'Email', href: 'mailto:mie15525063800@outlook.com', icon: 'email' },
];

const currentYear = new Date().getFullYear();
---

<footer class="footer glass">
  <div class="container footer-content">
    <div class="footer-info">
      <p class="copyright">© {currentYear} StarBlog. All rights reserved.</p>
      <p class="tagline">探索无垠星辰，记录每一个故事</p>
    </div>

    <div class="social-links">
      {socialLinks.map(link => (
        <a href={link.href} class="social-link" target="_blank" rel="noopener noreferrer" aria-label={link.name}>
          {link.icon === 'github' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          )}
          {link.icon === 'twitter' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          )}
          {link.icon === 'email' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="M22 6L12 13L2 6"/>
            </svg>
          )}
        </a>
      ))}
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    z-index: 50;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding: var(--spacing-lg) 0;
    margin-top: 0;
    background: rgba(10, 10, 15, 0.95);
  }

  .footer-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .copyright {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .tagline {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    opacity: 0.6;
  }

  .social-links {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--color-text-secondary);
    transition: all var(--transition-fast);
  }

  .social-link:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
    box-shadow: 0 0 20px rgba(107, 140, 255, 0.4);
  }

  @media (max-width: 768px) {
    .footer-content {
      flex-direction: column;
      gap: var(--spacing-sm);
      text-align: center;
    }
  }
</style>
