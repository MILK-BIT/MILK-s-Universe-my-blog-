---
// 星辰背景组件 - 每颗星代表一篇文章
interface Star {
  id: string;
  title: string;
  href: string;
  cluster: string;
  color: string;
}

interface Props {
  stars?: Star[];
  showInteractive?: boolean; // 是否显示可交互星辰
}

const { stars = [], showInteractive = false } = Astro.props;

// 星团位置（百分比）
const clusterCenters: Record<string, {x: number, y: number}> = {
  notes: { x: 30, y: 40 },
  photography: { x: 70, y: 35 },
  research: { x: 35, y: 65 },
  others: { x: 65, y: 60 }
};

// 计算每颗星的位置
function getStarData(star: Star, index: number, allStars: Star[]) {
  const center = clusterCenters[star.cluster];
  const clusterIndex = allStars.filter((s, i) => s.cluster === star.cluster && i < index).length;
  const angle = (clusterIndex * 55) * (Math.PI / 180);
  const radius = 15 + clusterIndex * 10;
  return {
    x: center.x + Math.cos(angle) * radius * 0.35,
    y: center.y + Math.sin(angle) * radius * 0.25,
    size: 5 + (clusterIndex % 3) * 2,
    delay: clusterIndex * 0.08
  };
}
---

<div class="starfield-container">
  <canvas id="starfield-bg"></canvas>

  {showInteractive && (
    <>
      <!-- 可交互的星辰 -->
      <div class="stars-interactive">
        {stars.map((star, index) => {
          const data = getStarData(star, index, stars);
          return (
            <a
              href={star.href}
              class="star-link"
              style={`--star-color: ${star.color}; --star-x: ${data.x}%; --star-y: ${data.y}%; --star-size: ${data.size}px; --star-delay: ${data.delay}s;`}
            >
              <span class="star-core"></span>
              <span class="star-ring"></span>
              <span class="star-glow"></span>
              <span class="star-label">{star.title}</span>
            </a>
          );
        })}
      </div>

      <!-- 星团名称 -->
      <div class="cluster-names">
        <div class="cluster-name" style="--color: #ff6b9d; --x: 30%; --y: 40%;">
          <span class="name-text">文稿</span>
        </div>
        <div class="cluster-name" style="--color: #4ecdc4; --x: 70%; --y: 35%;">
          <span class="name-text">摄影</span>
        </div>
        <div class="cluster-name" style="--color: #a78bfa; --x: 35%; --y: 65%;">
          <span class="name-text">科研</span>
        </div>
        <div class="cluster-name" style="--color: #fbbf24; --x: 65%; --y: 60%;">
          <span class="name-text">其他</span>
        </div>
      </div>
    </>
  )}
</div>

<style>
  .starfield-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    overflow: hidden;
    background: #0a0a0f;
  }

  #starfield-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .stars-interactive {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 10;
  }

  .star-link {
    position: absolute;
    left: var(--star-x);
    top: var(--star-y);
    transform: translate(-50%, -50%);
    cursor: pointer;
    animation: starAppear 1s ease-out forwards;
    animation-delay: var(--star-delay);
    opacity: 0;
    text-decoration: none;
    display: block;
  }

  @keyframes starAppear {
    0% {
      opacity: 0;
      transform: translate(-50%, -50%) scale(0);
    }
    60% {
      transform: translate(-50%, -50%) scale(1.3);
    }
    100% {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1);
    }
  }

  .star-core {
    display: block;
    width: var(--star-size);
    height: var(--star-size);
    background: var(--star-color);
    border-radius: 50%;
    transition: all 0.3s ease;
    box-shadow: 0 0 8px var(--star-color), 0 0 15px var(--star-color);
  }

  .star-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: calc(var(--star-size) * 2);
    height: calc(var(--star-size) * 2);
    border: 1.5px solid var(--star-color);
    border-radius: 50%;
    opacity: 0.3;
    transition: all 0.3s ease;
    pointer-events: none;
  }

  .star-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: calc(var(--star-size) * 3);
    height: calc(var(--star-size) * 3);
    background: radial-gradient(circle, var(--star-color) 0%, transparent 70%);
    opacity: 0.4;
    transition: all 0.3s ease;
    pointer-events: none;
  }

  .star-label {
    position: absolute;
    bottom: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%);
    background: rgba(15, 15, 25, 0.95);
    border: 1.5px solid var(--star-color);
    padding: 8px 14px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 500;
    white-space: nowrap;
    color: #fff;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    pointer-events: none;
    box-shadow: 0 0 20px color-mix(in srgb, var(--star-color) 50%, transparent);
    z-index: 100;
  }

  .star-label::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 6px solid transparent;
    border-top-color: var(--star-color);
  }

  /* 悬停效果 */
  .star-link:hover .star-core {
    transform: scale(2);
    box-shadow: 0 0 20px var(--star-color), 0 0 40px var(--star-color), 0 0 60px var(--star-color);
  }

  .star-link:hover .star-ring {
    width: calc(var(--star-size) * 4);
    height: calc(var(--star-size) * 4);
    opacity: 0.8;
    animation: ringPulse 1s ease-in-out infinite;
  }

  @keyframes ringPulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.8; }
    50% { transform: translate(-50%, -50%) scale(1.2); opacity: 0.4; }
  }

  .star-link:hover .star-glow {
    width: calc(var(--star-size) * 8);
    height: calc(var(--star-size) * 8);
    opacity: 0.6;
  }

  .star-link:hover .star-label {
    opacity: 1;
    visibility: visible;
  }

  /* 星团名称 */
  .cluster-names {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 5;
    pointer-events: none;
  }

  .cluster-name {
    position: absolute;
    left: var(--x);
    top: var(--y);
    transform: translate(-50%, -50%);
    opacity: 0;
    animation: fadeIn 2s ease forwards;
    animation-delay: 0.5s;
  }

  @keyframes fadeIn {
    to { opacity: 0.7; }
  }

  .name-text {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color);
    text-shadow: 0 0 25px var(--color), 0 0 50px var(--color);
    letter-spacing: 0.2em;
  }

  @media (max-width: 768px) {
    .star-label {
      font-size: 11px;
      padding: 6px 10px;
    }

    .name-text {
      font-size: 1rem;
    }
  }
</style>

<script>
  class StarfieldBackground {
    canvas: HTMLCanvasElement;
    ctx: CanvasRenderingContext2D;
    stars: Array<{
      x: number;
      y: number;
      size: number;
      opacity: number;
      twinkleSpeed: number;
      twinklePhase: number;
    }>;
    shootingStars: Array<{
      x: number;
      y: number;
      length: number;
      speed: number;
      angle: number;
      opacity: number;
      active: boolean;
    }>;
    animationId: number | null;

    constructor() {
      this.canvas = document.getElementById('starfield-bg') as HTMLCanvasElement;
      this.ctx = this.canvas.getContext('2d')!;
      this.stars = [];
      this.shootingStars = [];
      this.animationId = null;
      this.init();
    }

    init() {
      this.resize();
      this.createStars();
      this.createShootingStars();
      window.addEventListener('resize', () => this.resize());
      this.animate();
    }

    resize() {
      this.canvas.width = window.innerWidth;
      this.canvas.height = window.innerHeight;
      this.createStars();
    }

    createStars() {
      this.stars = [];
      const count = Math.floor((this.canvas.width * this.canvas.height) / 6000);

      for (let i = 0; i < count; i++) {
        this.stars.push({
          x: Math.random() * this.canvas.width,
          y: Math.random() * this.canvas.height,
          size: Math.random() * 1.5 + 0.5,
          opacity: Math.random() * 0.5 + 0.2,
          twinkleSpeed: Math.random() * 0.02 + 0.005,
          twinklePhase: Math.random() * Math.PI * 2
        });
      }
    }

    createShootingStars() {
      for (let i = 0; i < 5; i++) {
        this.shootingStars.push({
          x: 0,
          y: 0,
          length: 60 + Math.random() * 40,
          speed: 6 + Math.random() * 6,
          angle: Math.PI / 4 + Math.random() * 0.3,
          opacity: 0,
          active: false
        });
      }
    }

    animate() {
      this.ctx.fillStyle = '#0a0a0f';
      this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);

      // 星云
      const gradient = this.ctx.createRadialGradient(
        this.canvas.width * 0.5, this.canvas.height * 0.5, 0,
        this.canvas.width * 0.5, this.canvas.height * 0.5, this.canvas.width * 0.6
      );
      gradient.addColorStop(0, 'rgba(107, 140, 255, 0.03)');
      gradient.addColorStop(0.5, 'rgba(167, 139, 250, 0.02)');
      gradient.addColorStop(1, 'rgba(0, 0, 0, 0)');
      this.ctx.fillStyle = gradient;
      this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);

      // 背景星星
      this.stars.forEach(star => {
        star.twinklePhase += star.twinkleSpeed;
        const opacity = star.opacity + Math.sin(star.twinklePhase) * 0.2;

        this.ctx.beginPath();
        this.ctx.fillStyle = `rgba(255, 255, 255, ${opacity})`;
        this.ctx.arc(star.x, star.y, star.size, 0, Math.PI * 2);
        this.ctx.fill();
      });

      // 随机触发流星
      if (Math.random() < 0.008) {
        const inactive = this.shootingStars.find(s => !s.active);
        if (inactive) {
          inactive.active = true;
          inactive.x = Math.random() * this.canvas.width * 0.8;
          inactive.y = Math.random() * this.canvas.height * 0.3;
          inactive.opacity = Math.random() * 0.6 + 0.4;
          inactive.angle = Math.PI / 4 + Math.random() * 0.3;
          inactive.length = 60 + Math.random() * 60;
          inactive.speed = 8 + Math.random() * 8;
        }
      }

      // 绘制流星
      this.shootingStars.forEach(star => {
        if (!star.active) return;

        star.x += Math.cos(star.angle) * star.speed;
        star.y += Math.sin(star.angle) * star.speed;

        if (star.x > this.canvas.width || star.y > this.canvas.height) {
          star.active = false;
          return;
        }

        const tailX = star.x - Math.cos(star.angle) * star.length;
        const tailY = star.y - Math.sin(star.angle) * star.length;

        const gradient = this.ctx.createLinearGradient(tailX, tailY, star.x, star.y);
        gradient.addColorStop(0, 'rgba(255, 255, 255, 0)');
        gradient.addColorStop(0.5, `rgba(255, 255, 255, ${star.opacity * 0.5})`);
        gradient.addColorStop(1, `rgba(255, 255, 255, ${star.opacity})`);

        this.ctx.beginPath();
        this.ctx.strokeStyle = gradient;
        this.ctx.lineWidth = 2;
        this.ctx.lineCap = 'round';
        this.ctx.moveTo(tailX, tailY);
        this.ctx.lineTo(star.x, star.y);
        this.ctx.stroke();

        // 流星头部发光
        const headGlow = this.ctx.createRadialGradient(star.x, star.y, 0, star.x, star.y, 8);
        headGlow.addColorStop(0, `rgba(255, 255, 255, ${star.opacity})`);
        headGlow.addColorStop(1, 'rgba(255, 255, 255, 0)');
        this.ctx.beginPath();
        this.ctx.fillStyle = headGlow;
        this.ctx.arc(star.x, star.y, 8, 0, Math.PI * 2);
        this.ctx.fill();
      });

      this.animationId = requestAnimationFrame(() => this.animate());
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    new StarfieldBackground();
  });
</script>
