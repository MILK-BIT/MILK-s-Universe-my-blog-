[["Map",1,2,9,10,159,160,280,281,387,388],"meta::meta",["Map",3,4,5,6,7,8],"astro-version","5.18.1","content-config-digest","305362903143d906","astro-config-digest","{\"root\":{},\"srcDir\":{},\"publicDir\":{},\"outDir\":{},\"cacheDir\":{},\"site\":\"https://your-domain.com\",\"compressHTML\":true,\"base\":\"/\",\"trailingSlash\":\"ignore\",\"output\":\"static\",\"scopedStyleStrategy\":\"attribute\",\"build\":{\"format\":\"directory\",\"client\":{},\"server\":{},\"assets\":\"_astro\",\"serverEntry\":\"entry.mjs\",\"redirects\":true,\"inlineStylesheets\":\"auto\",\"concurrency\":1},\"server\":{\"open\":false,\"host\":false,\"port\":4321,\"streaming\":true,\"allowedHosts\":[]},\"redirects\":{},\"image\":{\"endpoint\":{\"route\":\"/_image\"},\"service\":{\"entrypoint\":\"astro/assets/services/sharp\",\"config\":{}},\"domains\":[],\"remotePatterns\":[],\"responsiveStyles\":false},\"devToolbar\":{\"enabled\":true},\"markdown\":{\"syntaxHighlight\":{\"type\":\"shiki\",\"excludeLangs\":[\"math\"]},\"shikiConfig\":{\"langs\":[],\"langAlias\":{},\"theme\":\"github-dark\",\"themes\":{},\"wrap\":false,\"transformers\":[]},\"remarkPlugins\":[],\"rehypePlugins\":[],\"remarkRehype\":{},\"gfm\":true,\"smartypants\":true},\"security\":{\"checkOrigin\":true,\"allowedDomains\":[],\"actionBodySizeLimit\":1048576},\"env\":{\"schema\":{},\"validateSecrets\":false},\"experimental\":{\"clientPrerender\":false,\"contentIntellisense\":false,\"headingIdCompat\":false,\"preserveScriptOrder\":false,\"liveContentCollections\":false,\"csp\":false,\"staticImportMetaEnv\":false,\"chromeDevtoolsWorkspace\":false,\"failOnPrerenderConflict\":false,\"svgo\":false},\"legacy\":{\"collections\":false}}","notes",["Map",11,12,44,45,94,95,135,136],"about-web",{"id":11,"data":13,"body":20,"filePath":21,"digest":22,"rendered":23,"legacyId":43},{"title":14,"description":15,"date":16,"tags":17},"关于我的博客与构建历程","About my blog",["Date","2026-04-01T00:00:00.000Z"],[18,19],"技术","感想","## 想法的诞生\n\n最近看到了很多佬的博客，感觉把笔记整理为网站是一件很有趣且美观的事情，正好也想尝试一下vibe coding，遂快速构思了一个以星辰为主题的UI设计并驱使Gemini帮我生成了页面图纸，再将图纸和描述一并投给Claude Code，历时一天 & 30 元就完成了一个仍有些bug的个人网站。\n\n## 关于AI的选择\n据说国内最好的Code LLM是GLM，遂使用 **CC Switch + GLM-5 +Claude Code** 完成\n\n## 关于架构\n因为这个网站本身是作为博客使用的，一开始本打算直接用MkDocs，但作为静态网站它过于丑陋，在github上参考了不少博主后决定使用 **Astro+Typescript**搭建，技术栈如下：\n|技术|\t说明|\n|---|---|\n|Astro 5.18.1|\t静态站点生成器|\n|TypeScript|\t类型安全|\n|Node.js\t|运行时环境|\n|CSS3|\t动画、渐变、变换|\n|Canvas API|\t星空背景渲染|\n|CSS 变量\t|主题颜色、响应式设计|\n| Glass效果 | backdrop-filter: blur |\n\n## 关于未来构想\n作为很爱跳舞的小女孩其实想开发一个舞蹈专栏，可以把舞蹈视频和我上传的视频对齐，但这以后再弄吧，感觉今天浪费了一天浅尝了以下vibe coding的快乐（很速度）与痛苦（很空虚QAQ什么也没学到），打算先消化一下\n\n---","src/content/notes/about-web.md","50aa2ba9a40d747f",{"html":24,"metadata":25},"\u003Ch2 id=\"想法的诞生\">想法的诞生\u003C/h2>\n\u003Cp>最近看到了很多佬的博客，感觉把笔记整理为网站是一件很有趣且美观的事情，正好也想尝试一下vibe coding，遂快速构思了一个以星辰为主题的UI设计并驱使Gemini帮我生成了页面图纸，再将图纸和描述一并投给Claude Code，历时一天 &#x26; 30 元就完成了一个仍有些bug的个人网站。\u003C/p>\n\u003Ch2 id=\"关于ai的选择\">关于AI的选择\u003C/h2>\n\u003Cp>据说国内最好的Code LLM是GLM，遂使用 \u003Cstrong>CC Switch + GLM-5 +Claude Code\u003C/strong> 完成\u003C/p>\n\u003Ch2 id=\"关于架构\">关于架构\u003C/h2>\n\u003Cp>因为这个网站本身是作为博客使用的，一开始本打算直接用MkDocs，但作为静态网站它过于丑陋，在github上参考了不少博主后决定使用 \u003Cstrong>Astro+Typescript\u003C/strong>搭建，技术栈如下：\u003C/p>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\u003Ctable>\u003Cthead>\u003Ctr>\u003Cth>技术\u003C/th>\u003Cth>说明\u003C/th>\u003C/tr>\u003C/thead>\u003Ctbody>\u003Ctr>\u003Ctd>Astro 5.18.1\u003C/td>\u003Ctd>静态站点生成器\u003C/td>\u003C/tr>\u003Ctr>\u003Ctd>TypeScript\u003C/td>\u003Ctd>类型安全\u003C/td>\u003C/tr>\u003Ctr>\u003Ctd>Node.js\u003C/td>\u003Ctd>运行时环境\u003C/td>\u003C/tr>\u003Ctr>\u003Ctd>CSS3\u003C/td>\u003Ctd>动画、渐变、变换\u003C/td>\u003C/tr>\u003Ctr>\u003Ctd>Canvas API\u003C/td>\u003Ctd>星空背景渲染\u003C/td>\u003C/tr>\u003Ctr>\u003Ctd>CSS 变量\u003C/td>\u003Ctd>主题颜色、响应式设计\u003C/td>\u003C/tr>\u003Ctr>\u003Ctd>Glass效果\u003C/td>\u003Ctd>backdrop-filter: blur\u003C/td>\u003C/tr>\u003C/tbody>\u003C/table>\n\u003Ch2 id=\"关于未来构想\">关于未来构想\u003C/h2>\n\u003Cp>作为很爱跳舞的小女孩其实想开发一个舞蹈专栏，可以把舞蹈视频和我上传的视频对齐，但这以后再弄吧，感觉今天浪费了一天浅尝了以下vibe coding的快乐（很速度）与痛苦（很空虚QAQ什么也没学到），打算先消化一下\u003C/p>\n\u003Chr>",{"headings":26,"localImagePaths":37,"remoteImagePaths":38,"frontmatter":39,"imagePaths":42},[27,30,33,35],{"depth":28,"slug":29,"text":29},2,"想法的诞生",{"depth":28,"slug":31,"text":32},"关于ai的选择","关于AI的选择",{"depth":28,"slug":34,"text":34},"关于架构",{"depth":28,"slug":36,"text":36},"关于未来构想",[],[],{"title":14,"description":15,"date":40,"tags":41},["Date","2026-04-01T00:00:00.000Z"],[18,19],[],"about-web.md","zettelkasten",{"id":44,"data":46,"body":53,"filePath":54,"digest":55,"rendered":56,"legacyId":93},{"title":47,"description":48,"date":49,"tags":50},"卡片笔记法实践","Zettelkasten方法的学习与实践",["Date","2024-03-05T00:00:00.000Z"],[51,52],"知识管理","学习方法","# 卡片笔记法实践\n\n## 什么是卡片笔记法？\n\n卡片笔记法（Zettelkasten）是德国社会学家尼克拉斯·卢曼发明的一种知识管理方法。卢曼一生出版了超过70本书籍和400篇学术文章，很大程度上归功于这个方法。\n\n> \"我不思考，我只是把笔记放进盒子里。\" —— 尼克拉斯·卢曼\n\n## 核心原则\n\n### 1. 原子化\n\n每张笔记只包含**一个想法**：\n\n- ✅ 一个概念、一个观点、一个事实\n- ❌ 不要把多个主题混在一起\n\n### 2. 用自己的话写\n\n不是简单的摘抄，而是：\n\n- 理解后的重新表达\n- 加入自己的思考和见解\n- 建立与已有知识的联系\n\n### 3. 建立连接\n\n笔记之间通过链接形成网络：\n\n```\n[[学习笔记]] → [[卡片笔记法]]\n     ↓\n[[知识管理工具]]\n     ↓\n[[Obsidian使用技巧]]\n```\n\n## 我的实践\n\n### 工具选择\n\n目前使用 **Obsidian** 作为主要工具：\n\n- 本地存储，数据安全\n- 双向链接\n- 图谱视图\n- 丰富的插件生态\n\n### 工作流程\n\n```\n阅读/学习 → 闪念笔记 → 永久笔记 → 索引笔记\n    ↓           ↓           ↓\n  高亮       整理思考     建立连接\n```\n\n### 每日习惯\n\n1. **晨间回顾**：浏览昨天的笔记，建立连接\n2. **随时记录**：使用手机快速捕捉想法\n3. **晚间整理**：将闪念笔记转化为永久笔记\n\n## 收获与反思\n\n坚持使用卡片笔记法一年后：\n\n- 知识不再孤立，而是形成网络\n- 写作变得更容易，素材信手拈来\n- 思考更加深入，能看到事物间的联系\n\n---\n\n**推荐阅读**：《卡片笔记写作法》—— 申克·阿伦斯","src/content/notes/zettelkasten.md","62c3971940dfbdac",{"html":57,"metadata":58},"\u003Ch1 id=\"卡片笔记法实践\">卡片笔记法实践\u003C/h1>\n\u003Ch2 id=\"什么是卡片笔记法\">什么是卡片笔记法？\u003C/h2>\n\u003Cp>卡片笔记法（Zettelkasten）是德国社会学家尼克拉斯·卢曼发明的一种知识管理方法。卢曼一生出版了超过70本书籍和400篇学术文章，很大程度上归功于这个方法。\u003C/p>\n\u003Cblockquote>\n\u003Cp>“我不思考，我只是把笔记放进盒子里。” —— 尼克拉斯·卢曼\u003C/p>\n\u003C/blockquote>\n\u003Ch2 id=\"核心原则\">核心原则\u003C/h2>\n\u003Ch3 id=\"1-原子化\">1. 原子化\u003C/h3>\n\u003Cp>每张笔记只包含\u003Cstrong>一个想法\u003C/strong>：\u003C/p>\n\u003Cul>\n\u003Cli>✅ 一个概念、一个观点、一个事实\u003C/li>\n\u003Cli>❌ 不要把多个主题混在一起\u003C/li>\n\u003C/ul>\n\u003Ch3 id=\"2-用自己的话写\">2. 用自己的话写\u003C/h3>\n\u003Cp>不是简单的摘抄，而是：\u003C/p>\n\u003Cul>\n\u003Cli>理解后的重新表达\u003C/li>\n\u003Cli>加入自己的思考和见解\u003C/li>\n\u003Cli>建立与已有知识的联系\u003C/li>\n\u003C/ul>\n\u003Ch3 id=\"3-建立连接\">3. 建立连接\u003C/h3>\n\u003Cp>笔记之间通过链接形成网络：\u003C/p>\n\u003Cpre class=\"astro-code github-dark\" style=\"background-color:#24292e;color:#e1e4e8; overflow-x: auto;\" tabindex=\"0\" data-language=\"plaintext\">\u003Ccode>\u003Cspan class=\"line\">\u003Cspan>[[学习笔记]] → [[卡片笔记法]]\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan>     ↓\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan>[[知识管理工具]]\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan>     ↓\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan>[[Obsidian使用技巧]]\u003C/span>\u003C/span>\u003C/code>\u003C/pre>\n\u003Ch2 id=\"我的实践\">我的实践\u003C/h2>\n\u003Ch3 id=\"工具选择\">工具选择\u003C/h3>\n\u003Cp>目前使用 \u003Cstrong>Obsidian\u003C/strong> 作为主要工具：\u003C/p>\n\u003Cul>\n\u003Cli>本地存储，数据安全\u003C/li>\n\u003Cli>双向链接\u003C/li>\n\u003Cli>图谱视图\u003C/li>\n\u003Cli>丰富的插件生态\u003C/li>\n\u003C/ul>\n\u003Ch3 id=\"工作流程\">工作流程\u003C/h3>\n\u003Cpre class=\"astro-code github-dark\" style=\"background-color:#24292e;color:#e1e4e8; overflow-x: auto;\" tabindex=\"0\" data-language=\"plaintext\">\u003Ccode>\u003Cspan class=\"line\">\u003Cspan>阅读/学习 → 闪念笔记 → 永久笔记 → 索引笔记\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan>    ↓           ↓           ↓\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan>  高亮       整理思考     建立连接\u003C/span>\u003C/span>\u003C/code>\u003C/pre>\n\u003Ch3 id=\"每日习惯\">每日习惯\u003C/h3>\n\u003Col>\n\u003Cli>\u003Cstrong>晨间回顾\u003C/strong>：浏览昨天的笔记，建立连接\u003C/li>\n\u003Cli>\u003Cstrong>随时记录\u003C/strong>：使用手机快速捕捉想法\u003C/li>\n\u003Cli>\u003Cstrong>晚间整理\u003C/strong>：将闪念笔记转化为永久笔记\u003C/li>\n\u003C/ol>\n\u003Ch2 id=\"收获与反思\">收获与反思\u003C/h2>\n\u003Cp>坚持使用卡片笔记法一年后：\u003C/p>\n\u003Cul>\n\u003Cli>知识不再孤立，而是形成网络\u003C/li>\n\u003Cli>写作变得更容易，素材信手拈来\u003C/li>\n\u003Cli>思考更加深入，能看到事物间的联系\u003C/li>\n\u003C/ul>\n\u003Chr>\n\u003Cp>\u003Cstrong>推荐阅读\u003C/strong>：《卡片笔记写作法》—— 申克·阿伦斯\u003C/p>",{"headings":59,"localImagePaths":87,"remoteImagePaths":88,"frontmatter":89,"imagePaths":92},[60,62,65,67,71,74,77,79,81,83,85],{"depth":61,"slug":47,"text":47},1,{"depth":28,"slug":63,"text":64},"什么是卡片笔记法","什么是卡片笔记法？",{"depth":28,"slug":66,"text":66},"核心原则",{"depth":68,"slug":69,"text":70},3,"1-原子化","1. 原子化",{"depth":68,"slug":72,"text":73},"2-用自己的话写","2. 用自己的话写",{"depth":68,"slug":75,"text":76},"3-建立连接","3. 建立连接",{"depth":28,"slug":78,"text":78},"我的实践",{"depth":68,"slug":80,"text":80},"工具选择",{"depth":68,"slug":82,"text":82},"工作流程",{"depth":68,"slug":84,"text":84},"每日习惯",{"depth":28,"slug":86,"text":86},"收获与反思",[],[],{"title":47,"description":48,"date":90,"tags":91},["Date","2024-03-05T00:00:00.000Z"],[51,52],[],"zettelkasten.md","python-tips",{"id":94,"data":96,"body":103,"filePath":104,"digest":105,"rendered":106,"legacyId":134},{"title":97,"description":98,"date":99,"tags":100},"Python 学习笔记","Python常用技巧和最佳实践整理",["Date","2024-03-15T00:00:00.000Z"],[101,102],"编程","Python","# Python 学习笔记\n\n## 基础语法\n\n### 变量和数据类型\n\nPython是动态类型语言，变量不需要声明类型：\n\n```python\nname = \"Alice\"      # 字符串\nage = 25            # 整数\nheight = 1.75       # 浮点数\nis_student = True   # 布尔值\n```\n\n### 列表推导式\n\n列表推导式是Python的一大特色，可以用简洁的语法创建列表：\n\n```python\n# 普通写法\nsquares = []\nfor x in range(10):\n    squares.append(x ** 2)\n\n# 列表推导式\nsquares = [x ** 2 for x in range(10)]\n\n# 带条件的列表推导式\neven_squares = [x ** 2 for x in range(10) if x % 2 == 0]\n```\n\n## 常用技巧\n\n### 字典的 get 方法\n\n使用 `get` 方法可以避免 KeyError：\n\n```python\ndata = {'name': 'Alice', 'age': 25}\n\n# 不推荐\ntry:\n    city = data['city']\nexcept KeyError:\n    city = 'Unknown'\n\n# 推荐\ncity = data.get('city', 'Unknown')\n```\n\n### enumerate 和 zip\n\n```python\n# enumerate: 同时获取索引和值\nfor i, item in enumerate(['a', 'b', 'c']):\n    print(f\"{i}: {item}\")\n\n# zip: 并行迭代多个列表\nnames = ['Alice', 'Bob', 'Charlie']\nages = [25, 30, 35]\nfor name, age in zip(names, ages):\n    print(f\"{name} is {age} years old\")\n```\n\n## 最佳实践\n\n1. **使用 with 语句处理资源**：确保文件等资源正确关闭\n2. **遵循 PEP 8 编码规范**：保持代码风格一致\n3. **编写文档字符串**：为函数和类添加说明\n4. **使用类型注解**：提高代码可读性\n\n---\n\n*持续更新中...*","src/content/notes/python-tips.md","48d714209f7ac892",{"html":107,"metadata":108},"\u003Ch1 id=\"python-学习笔记\">Python 学习笔记\u003C/h1>\n\u003Ch2 id=\"基础语法\">基础语法\u003C/h2>\n\u003Ch3 id=\"变量和数据类型\">变量和数据类型\u003C/h3>\n\u003Cp>Python是动态类型语言，变量不需要声明类型：\u003C/p>\n\u003Cpre class=\"astro-code github-dark\" style=\"background-color:#24292e;color:#e1e4e8; overflow-x: auto;\" tabindex=\"0\" data-language=\"python\">\u003Ccode>\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">name \u003C/span>\u003Cspan style=\"color:#F97583\">=\u003C/span>\u003Cspan style=\"color:#9ECBFF\"> \"Alice\"\u003C/span>\u003Cspan style=\"color:#6A737D\">      # 字符串\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">age \u003C/span>\u003Cspan style=\"color:#F97583\">=\u003C/span>\u003Cspan style=\"color:#79B8FF\"> 25\u003C/span>\u003Cspan style=\"color:#6A737D\">            # 整数\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">height \u003C/span>\u003Cspan style=\"color:#F97583\">=\u003C/span>\u003Cspan style=\"color:#79B8FF\"> 1.75\u003C/span>\u003Cspan style=\"color:#6A737D\">       # 浮点数\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">is_student \u003C/span>\u003Cspan style=\"color:#F97583\">=\u003C/span>\u003Cspan style=\"color:#79B8FF\"> True\u003C/span>\u003Cspan style=\"color:#6A737D\">   # 布尔值\u003C/span>\u003C/span>\u003C/code>\u003C/pre>\n\u003Ch3 id=\"列表推导式\">列表推导式\u003C/h3>\n\u003Cp>列表推导式是Python的一大特色，可以用简洁的语法创建列表：\u003C/p>\n\u003Cpre class=\"astro-code github-dark\" style=\"background-color:#24292e;color:#e1e4e8; overflow-x: auto;\" tabindex=\"0\" data-language=\"python\">\u003Ccode>\u003Cspan class=\"line\">\u003Cspan style=\"color:#6A737D\"># 普通写法\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">squares \u003C/span>\u003Cspan style=\"color:#F97583\">=\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> []\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#F97583\">for\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> x \u003C/span>\u003Cspan style=\"color:#F97583\">in\u003C/span>\u003Cspan style=\"color:#79B8FF\"> range\u003C/span>\u003Cspan style=\"color:#E1E4E8\">(\u003C/span>\u003Cspan style=\"color:#79B8FF\">10\u003C/span>\u003Cspan style=\"color:#E1E4E8\">):\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">    squares.append(x \u003C/span>\u003Cspan style=\"color:#F97583\">**\u003C/span>\u003Cspan style=\"color:#79B8FF\"> 2\u003C/span>\u003Cspan style=\"color:#E1E4E8\">)\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#6A737D\"># 列表推导式\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">squares \u003C/span>\u003Cspan style=\"color:#F97583\">=\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> [x \u003C/span>\u003Cspan style=\"color:#F97583\">**\u003C/span>\u003Cspan style=\"color:#79B8FF\"> 2\u003C/span>\u003Cspan style=\"color:#F97583\"> for\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> x \u003C/span>\u003Cspan style=\"color:#F97583\">in\u003C/span>\u003Cspan style=\"color:#79B8FF\"> range\u003C/span>\u003Cspan style=\"color:#E1E4E8\">(\u003C/span>\u003Cspan style=\"color:#79B8FF\">10\u003C/span>\u003Cspan style=\"color:#E1E4E8\">)]\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#6A737D\"># 带条件的列表推导式\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">even_squares \u003C/span>\u003Cspan style=\"color:#F97583\">=\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> [x \u003C/span>\u003Cspan style=\"color:#F97583\">**\u003C/span>\u003Cspan style=\"color:#79B8FF\"> 2\u003C/span>\u003Cspan style=\"color:#F97583\"> for\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> x \u003C/span>\u003Cspan style=\"color:#F97583\">in\u003C/span>\u003Cspan style=\"color:#79B8FF\"> range\u003C/span>\u003Cspan style=\"color:#E1E4E8\">(\u003C/span>\u003Cspan style=\"color:#79B8FF\">10\u003C/span>\u003Cspan style=\"color:#E1E4E8\">) \u003C/span>\u003Cspan style=\"color:#F97583\">if\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> x \u003C/span>\u003Cspan style=\"color:#F97583\">%\u003C/span>\u003Cspan style=\"color:#79B8FF\"> 2\u003C/span>\u003Cspan style=\"color:#F97583\"> ==\u003C/span>\u003Cspan style=\"color:#79B8FF\"> 0\u003C/span>\u003Cspan style=\"color:#E1E4E8\">]\u003C/span>\u003C/span>\u003C/code>\u003C/pre>\n\u003Ch2 id=\"常用技巧\">常用技巧\u003C/h2>\n\u003Ch3 id=\"字典的-get-方法\">字典的 get 方法\u003C/h3>\n\u003Cp>使用 \u003Ccode>get\u003C/code> 方法可以避免 KeyError：\u003C/p>\n\u003Cpre class=\"astro-code github-dark\" style=\"background-color:#24292e;color:#e1e4e8; overflow-x: auto;\" tabindex=\"0\" data-language=\"python\">\u003Ccode>\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">data \u003C/span>\u003Cspan style=\"color:#F97583\">=\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> {\u003C/span>\u003Cspan style=\"color:#9ECBFF\">'name'\u003C/span>\u003Cspan style=\"color:#E1E4E8\">: \u003C/span>\u003Cspan style=\"color:#9ECBFF\">'Alice'\u003C/span>\u003Cspan style=\"color:#E1E4E8\">, \u003C/span>\u003Cspan style=\"color:#9ECBFF\">'age'\u003C/span>\u003Cspan style=\"color:#E1E4E8\">: \u003C/span>\u003Cspan style=\"color:#79B8FF\">25\u003C/span>\u003Cspan style=\"color:#E1E4E8\">}\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#6A737D\"># 不推荐\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#F97583\">try\u003C/span>\u003Cspan style=\"color:#E1E4E8\">:\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">    city \u003C/span>\u003Cspan style=\"color:#F97583\">=\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> data[\u003C/span>\u003Cspan style=\"color:#9ECBFF\">'city'\u003C/span>\u003Cspan style=\"color:#E1E4E8\">]\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#F97583\">except\u003C/span>\u003Cspan style=\"color:#79B8FF\"> KeyError\u003C/span>\u003Cspan style=\"color:#E1E4E8\">:\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">    city \u003C/span>\u003Cspan style=\"color:#F97583\">=\u003C/span>\u003Cspan style=\"color:#9ECBFF\"> 'Unknown'\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#6A737D\"># 推荐\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">city \u003C/span>\u003Cspan style=\"color:#F97583\">=\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> data.get(\u003C/span>\u003Cspan style=\"color:#9ECBFF\">'city'\u003C/span>\u003Cspan style=\"color:#E1E4E8\">, \u003C/span>\u003Cspan style=\"color:#9ECBFF\">'Unknown'\u003C/span>\u003Cspan style=\"color:#E1E4E8\">)\u003C/span>\u003C/span>\u003C/code>\u003C/pre>\n\u003Ch3 id=\"enumerate-和-zip\">enumerate 和 zip\u003C/h3>\n\u003Cpre class=\"astro-code github-dark\" style=\"background-color:#24292e;color:#e1e4e8; overflow-x: auto;\" tabindex=\"0\" data-language=\"python\">\u003Ccode>\u003Cspan class=\"line\">\u003Cspan style=\"color:#6A737D\"># enumerate: 同时获取索引和值\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#F97583\">for\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> i, item \u003C/span>\u003Cspan style=\"color:#F97583\">in\u003C/span>\u003Cspan style=\"color:#79B8FF\"> enumerate\u003C/span>\u003Cspan style=\"color:#E1E4E8\">([\u003C/span>\u003Cspan style=\"color:#9ECBFF\">'a'\u003C/span>\u003Cspan style=\"color:#E1E4E8\">, \u003C/span>\u003Cspan style=\"color:#9ECBFF\">'b'\u003C/span>\u003Cspan style=\"color:#E1E4E8\">, \u003C/span>\u003Cspan style=\"color:#9ECBFF\">'c'\u003C/span>\u003Cspan style=\"color:#E1E4E8\">]):\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#79B8FF\">    print\u003C/span>\u003Cspan style=\"color:#E1E4E8\">(\u003C/span>\u003Cspan style=\"color:#F97583\">f\u003C/span>\u003Cspan style=\"color:#9ECBFF\">\"\u003C/span>\u003Cspan style=\"color:#79B8FF\">{\u003C/span>\u003Cspan style=\"color:#E1E4E8\">i\u003C/span>\u003Cspan style=\"color:#79B8FF\">}\u003C/span>\u003Cspan style=\"color:#9ECBFF\">: \u003C/span>\u003Cspan style=\"color:#79B8FF\">{\u003C/span>\u003Cspan style=\"color:#E1E4E8\">item\u003C/span>\u003Cspan style=\"color:#79B8FF\">}\u003C/span>\u003Cspan style=\"color:#9ECBFF\">\"\u003C/span>\u003Cspan style=\"color:#E1E4E8\">)\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#6A737D\"># zip: 并行迭代多个列表\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">names \u003C/span>\u003Cspan style=\"color:#F97583\">=\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> [\u003C/span>\u003Cspan style=\"color:#9ECBFF\">'Alice'\u003C/span>\u003Cspan style=\"color:#E1E4E8\">, \u003C/span>\u003Cspan style=\"color:#9ECBFF\">'Bob'\u003C/span>\u003Cspan style=\"color:#E1E4E8\">, \u003C/span>\u003Cspan style=\"color:#9ECBFF\">'Charlie'\u003C/span>\u003Cspan style=\"color:#E1E4E8\">]\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">ages \u003C/span>\u003Cspan style=\"color:#F97583\">=\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> [\u003C/span>\u003Cspan style=\"color:#79B8FF\">25\u003C/span>\u003Cspan style=\"color:#E1E4E8\">, \u003C/span>\u003Cspan style=\"color:#79B8FF\">3